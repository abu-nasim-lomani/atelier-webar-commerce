{
  "name": "atelier-webar-commerce",
  "version": "0.1.0",
  "private": true,
  "description": "Cinematic WebAR furniture commerce — production scaffold (Phase A1)",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "pnpm tokens:build && next build",
    "start": "next start",
    "tokens:build": "tsx src/tokens/generate-css.ts",
    "tokens:check": "tsx src/tokens/generate-css.ts --check",
    "assets:optimize": "tsx assets-pipeline/optimize.ts",
    "assets:check": "tsx assets-pipeline/validate.ts",
    "lint": "eslint . --max-warnings=0",
    "lint:css": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "verify": "pnpm typecheck && pnpm lint && pnpm lint:css && pnpm tokens:check && pnpm assets:check"
  },
  "dependencies": {
    "@react-three/fiber": "9.0.0",
    "@react-three/xr": "^6.6.30",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "next": "15.5.18",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "three": "0.169.0",
    "use-sync-external-store": "^1.6.0",
    "zustand": "5.0.0"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.1.1",
    "@gltf-transform/extensions": "^4.1.1",
    "@gltf-transform/functions": "^4.1.1",
    "@types/node": "20.16.11",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@types/three": "0.169.0",
    "@typescript-eslint/eslint-plugin": "8.8.1",
    "@typescript-eslint/parser": "8.8.1",
    "eslint": "9.12.0",
    "eslint-config-next": "15.5.18",
    "eslint-plugin-boundaries": "5.0.1",
    "prettier": "3.3.3",
    "sharp": "^0.33.5",
    "stylelint": "16.9.0",
    "stylelint-config-standard": "36.0.1",
    "stylelint-declaration-strict-value": "1.10.6",
    "tsx": "4.19.1",
    "typescript": "5.6.3"
  }
}
